# Cross-editor defaults. Honored natively by Visual Studio, CLion, and most editors;
# VS Code needs the EditorConfig extension (in recommended extensions).
# Indent rules per file type intentionally match .clang-format and .cmake-format.yaml.
root = true

# Universal rules for every file.
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# C / C++ — tabs, width 4, 120 cols (mirrors .clang-format).
[*.{c,cc,cpp,cxx,h,hh,hpp,hxx}]
indent_style = tab
indent_size = 4
max_line_length = 120

# CMake — 2-space (mirrors .cmake-format.yaml).
[{CMakeLists.txt,*.cmake}]
indent_style = space
indent_size = 2

# YAML must use spaces. Covers .cmake-format.yaml, .pre-commit-config.yaml, CI workflows.
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Extensionless YAML dotfiles (clangd/clang-tidy/clang-format configs).
[{.clangd,.clang-tidy,.clang-format}]
indent_style = space
indent_size = 2

# JSON — tabs, matching the committed CMakePresets.json / vcpkg.json.
[*.json]
indent_style = tab
indent_size = 4

# ...except VS Code's JSONC config, which uses 2-space.
[.vscode/*.json]
indent_style = space
indent_size = 2

# Markdown: keep trailing whitespace (two spaces = hard line break).
[*.md]
trim_trailing_whitespace = false
